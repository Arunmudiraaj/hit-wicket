        "jsonwebtoken": "^9.0.3",
        "nanoid": "^5.0.7",
        "pino": "^9.4.0",
        "pino-pretty": "^11.2.2",
        "postgres": "^3.4.9",
        "socket.io": "^4.8.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^22.15.21",
        "@types/supertest": "^7.2.0",
        "drizzle-kit": "^0.31.10",
        "socket.io-client": "^4.8.1",
        "supertest": "^7.2.2",
